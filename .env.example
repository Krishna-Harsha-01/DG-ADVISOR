# ============================================================
#  AI Dangerous Goods Handling Compliance Advisor
#  Copy this file to ".env" and fill in your real values.
#  NEVER commit your real .env file to GitHub.
#
#  For local development: Use MySQL on localhost
#  For production (Vercel): Use PlanetScale, AWS RDS, or similar
# ============================================================

# Server port (the app will run at http://localhost:PORT)
PORT=3000

# ------------------------------------------------------------
#  DATABASE — MySQL
#  The app stores all data in MySQL. Make sure a MySQL server is
#  running, then set the login below. The app AUTO-CREATES the
#  database and tables on first run — you do NOT have to create
#  them by hand. Just make sure the user/password are correct.
#
#  LOCAL SETUP (development):
#    • MySQL installer / Workbench:  user "root", your root password
#    • XAMPP / WAMP:                 user "root", password "" (blank)
#
#  PRODUCTION SETUP (Vercel / cloud):
#    • Use PlanetScale (MySQL-compatible):  https://planetscale.com
#    • Use AWS RDS (MySQL):                 https://aws.amazon.com/rds
#    • Use Render (PostgreSQL):             https://render.com
#    • Connection string format:
#      mysql://username:password@host:3306/dg_advisor?sslaccept=strict
# ------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=dg_advisor

# ------------------------------------------------------------
#  AI PROVIDER  — choose ONE:  openrouter | gemini | openai | mock
#  Set AI_PROVIDER to match the key you have and paste it below.
#   openrouter : one key, many models. Key looks like  sk-or-v1-...
#   gemini     : Google Gemini.        Key looks like  AIza... or AQ...
#   openai     : OpenAI GPT.           Key looks like  sk-...
#   mock       : no key — instant offline demo (keyword only).
# ------------------------------------------------------------
AI_PROVIDER=openrouter

# --- OpenRouter (https://openrouter.ai/keys) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Max seconds to wait for the AI before timing out
AI_TIMEOUT_SECONDS=30

# ------------------------------------------------------------
#  AUTHENTICATION — shift-based staff access codes
#  Staff sign in with a personal 6-character code (starts "DG",
#  all capitals). Each staff member is on a SHIFT and can only log
#  in during their shift hours:
#     morning  06:00-14:00      evening  14:00-22:00
#     night    22:00-06:00
#  The 6 staff codes are AUTO-GENERATED in MySQL on first run and
#  printed to the terminal. The admin can also see them on the
#  "Access Log" page after signing in.
#
#  The ADMIN signs in with the code below (no shift limit) and can
#  view Analytics + the Access Log (who logged in and when).
# ------------------------------------------------------------
ADMIN_CODE=DGADMN
AUTH_SECRET=hk-shipping-change-this-secret-in-production
